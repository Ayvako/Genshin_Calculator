<UserControl x:Class="Genshin_Calculator.Presentation.Controls.LevelSelectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Genshin_Calculator.Presentation.Views"
             x:Name="root"
             Width="Auto" Height="Auto">

    <StackPanel HorizontalAlignment="Center">
        <!-- Заголовок: Current / Desired -->
        <TextBlock Text="{Binding Title, ElementName=root, FallbackValue=Title}"
                   Foreground="#AAA"
                   FontSize="12"
                   Margin="0 0 0 4"
                   HorizontalAlignment="Center" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

            <!-- MINUS -->
            <Button Width="30" Height="30" Padding="0"
                    Style="{StaticResource RoundedButtonStyle}"
                    Command="{Binding DecreaseLevelCommand, ElementName=root}">
                <Button.IsEnabled>
                    <Binding Path="Level" ElementName="root" Converter="{StaticResource LevelGreaterThanOneConverter}" />
                </Button.IsEnabled>
                <TextBlock Text="-" Margin="0,-8,0,0" FontSize="28" />
            </Button>

            <!-- SELECTOR -->
            <Border x:Name="TogglePopupButton"
                    Width="50" Height="29"
                    CornerRadius="2"
                    Background="#E8E2D4"
                    BorderBrush="#D4C8B8"
                    BorderThickness="1"
                    Cursor="Hand">

                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick" Command="{Binding TogglePopupCommand, ElementName=root}" />
                </Border.InputBindings>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="10*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="3*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Padding="0"
                               Text="{Binding Level, ElementName=root, FallbackValue=100}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#2C2C2C"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />

                    <Rectangle Grid.Row="1" Height="1" Fill="#C4B8A8" />

                    <TextBlock Grid.Row="2"
                               Text="▼"
                               FontSize="6"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- POPUP -->
            <Popup Placement="Bottom"
                   PlacementTarget="{Binding ElementName=TogglePopupButton}"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   IsOpen="{Binding IsPopupOpen, ElementName=root}">

                <Border Background="#1E1E1E"
                        BorderBrush="#444"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="6">

                    <StackPanel>

                        <!-- TOP -->
                        <Button Content="1" Style="{StaticResource RoundedButtonStyle}"
                                Width="70" Height="32" FontSize="22"
                                Padding="0"
                                HorizontalAlignment="Center"
                                Command="{Binding SelectLevelCommand, ElementName=root}"
                                CommandParameter="1" />

                        <!-- MID -->
                        <ItemsControl ItemsSource="{Binding LevelOptionsPairs, ElementName=root}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">

                                        <Button Content="{Binding Level}" Style="{StaticResource RoundedButtonStyle}"
                                                Width="70" Height="32"
                                                FontSize="22"
                                                Padding="0"
                                                Command="{Binding SelectLevelCommand, ElementName=root}"
                                                CommandParameter="{Binding Level}" />

                                        <Button Content="{Binding Ascended}" Style="{StaticResource RoundedButtonStyle}"
                                                Width="70" Height="32"
                                                FontSize="22"
                                                Padding="0"
                                                Command="{Binding SelectLevelCommand, ElementName=root}"
                                                CommandParameter="{Binding Ascended}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- BOTTOM -->
                        <Button Content="90" Style="{StaticResource RoundedButtonStyle}"
                                Width="70" Height="32"
                                FontSize="22"
                                Padding="0"
                                HorizontalAlignment="Center"
                                Command="{Binding SelectLevelCommand, ElementName=root}"
                                CommandParameter="90" />
                    </StackPanel>
                </Border>
            </Popup>

            <!-- PLUS -->
            <Button Width="30" Height="30" Padding="0"
                    Style="{StaticResource RoundedButtonStyle}"
                    Command="{Binding IncreaseLevelCommand, ElementName=root}">
                <Button.IsEnabled>
                    <Binding Path="Level" ElementName="root" Converter="{StaticResource LevelLessThanConverter}" ConverterParameter="90" />
                </Button.IsEnabled>
                <TextBlock Text="+" Margin="0,-8,0,0" FontSize="28" />
            </Button>

        </StackPanel>
    </StackPanel>
</UserControl>