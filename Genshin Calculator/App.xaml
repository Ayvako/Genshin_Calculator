<Application x:Class="Genshin_Calculator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Genshin_Calculator.Helpers.Converters"
             xmlns:local="clr-namespace:Genshin_Calculator">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:RarityToBrushConverter x:Key="RarityToBrushConverter" />
            <conv:ImagePathToSourceConverter x:Key="ImageConverter" />
            <conv:LevelGreaterThanOneConverter x:Key="LevelGreaterThanOneConverter" />
            <conv:LevelLessThanConverter x:Key="LevelLessThanConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>