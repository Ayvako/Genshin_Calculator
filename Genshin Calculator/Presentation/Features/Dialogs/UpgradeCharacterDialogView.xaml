<Window x:Class="Genshin_Calculator.Presentation.Features.Dialogs.UpgradeCharacterDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:Genshin_Calculator.Presentation.Controls"
        Height="540" Width="450" MinWidth="400" MinHeight="400"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E" Foreground="White"
        Title="Upgrade Character">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Character.Name, StringFormat='Upgrade {0}'}"
                   Foreground="{Binding Character.Assets.Rarity, Converter={StaticResource RarityToBrushConverter}}"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,15" HorizontalAlignment="Center" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0">
            <StackPanel>

                <ItemsControl ItemsSource="{Binding Materials}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.OpenAddItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding TargetMaterial}"
                                    Background="Transparent" BorderThickness="0" Padding="0" Margin="4" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CardBorder" CornerRadius="6" BorderBrush="#333" BorderThickness="1"
                                                Background="{Binding TargetMaterial.Rarity, Converter={StaticResource RarityToBrushConverter}}"
                                                Opacity="{Binding IsCollected, Converter={StaticResource BoolToOpacityConverter}}">

                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.4" Direction="270" />
                                            </Border.Effect>

                                            <Grid Width="56" Height="72">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="20" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0" Background="#CC000000" CornerRadius="5,5,0,0">
                                                    <TextBlock Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding MissingAmount}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCollected}" Value="True">
                                                                        <Setter Property="Text" Value="{Binding TargetMaterial.Amount}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding CraftedAmount, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" Value="True">
                                                                        <Setter Property="ToolTip" Value="{Binding CraftedAmount}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <Image Grid.Row="1" Source="{Binding TargetMaterial.ImagePath}"
                                                       Margin="4" Stretch="Uniform"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />

                                                <Grid Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2"
                                                      Visibility="{Binding IsCollected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Ellipse Fill="#252525" Width="18" Height="18" />
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73E;"
                                                               Foreground="#4CAF50" FontSize="12"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.85" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Margin="0,20,0,10">
                    <Separator Background="#333" Margin="30,0" />
                    <TextBlock Text="Crafting Requirements" HorizontalAlignment="Center" Foreground="#E2B062" FontWeight="Bold" Margin="0,10,0,2" />
                    <TextBlock Text="Base materials needed" FontSize="11" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,10" />

                    <ItemsControl ItemsSource="{Binding MaterialsToCraft}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenAddItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0" Padding="0" Margin="4" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="CraftBorder" Width="52" Height="64" CornerRadius="6" BorderBrush="#333" BorderThickness="1"
                                                    Background="{Binding Rarity, Converter={StaticResource RarityToBrushConverter}}">

                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="18" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>

                                                    <Border Grid.Row="0" Background="#CC000000" CornerRadius="5,5,0,0">
                                                        <TextBlock Text="{Binding Amount}" Foreground="#F0F0F0"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                                    </Border>

                                                    <Image Grid.Row="1" Source="{Binding ImagePath}"
                                                           Margin="4" Stretch="Uniform"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CraftBorder" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="✖" Style="{StaticResource RoundShadowButtonStyle}"
                    Margin="0,0,20,0" Width="36" Height="36" FontSize="14"
                    Background="#C84646" Foreground="White"
                    Command="{Binding CancelCommand}" IsCancel="True" />

            <Button Content="✔" Style="{StaticResource RoundShadowButtonStyle}"
                    Margin="20,0,0,0" Width="36" Height="36" FontSize="16"
                    Background="#419D5F" Foreground="White"
                    Command="{Binding SaveCommand}" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>