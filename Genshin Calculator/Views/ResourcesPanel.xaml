<UserControl x:Class="Genshin_Calculator.Views.ResourcesPanel"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             Height="Auto">
    <WrapPanel HorizontalAlignment="Center" Margin="5">
        <ItemsControl ItemsSource="{Binding MissingMaterials}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5" CornerRadius="10" Background="{Binding Rarity, Converter={StaticResource RarityToBrushConverter}}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <Border Background="Black" CornerRadius="10,10,0,0">
                                <TextBlock Text="{Binding Amount}" Foreground="White" TextAlignment="Center" Margin="6" />
                            </Border>
                            <Image Source="{Binding Image}" Stretch="None" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </WrapPanel>
</UserControl>