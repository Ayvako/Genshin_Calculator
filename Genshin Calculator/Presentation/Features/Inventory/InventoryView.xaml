<Window x:Class="Genshin_Calculator.Presentation.Features.Inventory.InventoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Genshin_Calculator.Presentation.Helpers"
        xmlns:inventory="clr-namespace:Genshin_Calculator.Presentation.Features.Inventory"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=inventory:InventoryViewModel}"
        Title="Inventory Manager"
        Height="760"
        Width="1000"
        MinHeight="650"
        MinWidth="850"
        WindowStartupLocation="CenterOwner"
        Background="#121214"
        FontFamily="Segoe UI"
        TextElement.Foreground="#F2F2F2">

    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBgBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#17181C" Offset="0" />
            <GradientStop Color="#101114" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#24262C" Offset="0" />
            <GradientStop Color="#1A1B20" Offset="1" />
        </LinearGradientBrush>

        <DropShadowEffect x:Key="SoftShadow" BlurRadius="18" ShadowDepth="0" Opacity="0.35" Color="Black" />

        <Style TargetType="TextBlock" x:Key="SectionTitleStyle">
            <Setter Property="Foreground" Value="#D9C08A" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="Border" x:Key="InventoryCardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#33363D" />
            <Setter Property="Background" Value="#2A2D33" />
            <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
            <Setter Property="Margin" Value="6" />
        </Style>

        <Style TargetType="TextBox" x:Key="AmountBoxStyle">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBgBrush}">
        <Border Margin="18"
                CornerRadius="18"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#2E3138"
                BorderThickness="1"
                Padding="18"
                Effect="{StaticResource SoftShadow}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding FilterOptions}"
                              SelectedItem="{Binding SelectedFilter}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Width="210"
                              Padding="10,7"
                              Background="#23252B"
                              Foreground="White"
                              BorderBrush="#3A3E46"
                              BorderThickness="1"
                              Style="{StaticResource ComboBoxStyle}"
                              ItemContainerStyle="{StaticResource ComboBoxItemStyle}" />
                </Grid>

                <!-- Content -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,2,0">
                    <ItemsControl ItemsSource="{Binding MaterialsView}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Margin" Value="0,0,0,18" />
                                    </Style>
                                </GroupStyle.ContainerStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Margin="2,8,2,8" Padding="10,6" CornerRadius="10" Background="#202228">
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource SectionTitleStyle}" />
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource InventoryCardStyle}"
                                    Width="70"
                                    Height="95"
                                    Background="{Binding Rarity, Converter={StaticResource RarityToBrushConverter}}"
                                    ToolTipService.InitialShowDelay="150"
                                    ToolTipService.ShowDuration="60000">

                                    <Border.ToolTip>
                                        <ToolTip Placement="Mouse"
                                            Background="Transparent"
                                            BorderThickness="0">

                                            <Border Width="220"
                                                Padding="12"
                                                CornerRadius="12"
                                                Background="#1E2026"
                                                BorderBrush="#3A3E46"
                                                BorderThickness="1">

                                                <StackPanel>
                                                    <Border CornerRadius="8"
                                                        Padding="6"
                                                        Margin="0,0,0,8"
                                                        Background="{Binding Rarity, Converter={StaticResource RarityToBrushConverter}}">
                                                        <TextBlock Text="{Binding Name}"
                                                            FontSize="15"
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            TextAlignment="Center" />
                                                    </Border>

                                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                                        <TextBlock Text="Количество:"
                                                            Foreground="#AAB0B6"
                                                            FontSize="13" />
                                                        <TextBlock Text="{Binding Amount}"
                                                            Margin="6,0,0,0"
                                                            FontWeight="SemiBold"
                                                            FontSize="13" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                        <TextBlock Text="Редкость:"
                                                            Foreground="#AAB0B6"
                                                            FontSize="13" />
                                                        <TextBlock Text="{Binding Rarity}"
                                                            Margin="6,0,0,0"
                                                            FontWeight="SemiBold"
                                                            FontSize="13" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </ToolTip>
                                    </Border.ToolTip>

                                    <Grid>
                                        <Image Source="{Binding ImagePath}"
                                            Width="50"
                                            Height="50"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Margin="0,10,0,0"
                                            RenderOptions.BitmapScalingMode="HighQuality" />
                                        <Border VerticalAlignment="Bottom"
                                            Margin="10"
                                            Background="#66000000"
                                            CornerRadius="8"
                                            Padding="4,2">
                                            <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                                helpers:TextBoxExtensions.NumericOnly="True"
                                                Style="{StaticResource AmountBoxStyle}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Footer buttons -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,18,0,0">

                    <Button Content="✖"
                            Command="{Binding CancelCommand}"
                            Width="52"
                            Height="52"
                            Margin="0,0,14,0"
                            Foreground="White"
                            Background="#C84E4E"
                            BorderThickness="0"
                            FontSize="18"
                            FontWeight="Bold"
                            Style="{StaticResource RoundShadowButtonStyle}" />

                    <Button Content="✔"
                            Command="{Binding SaveCommand}"
                            Width="52"
                            Height="52"
                            Margin="14,0,0,0"
                            Foreground="White"
                            Background="#4BA66B"
                            BorderThickness="0"
                            FontSize="18"
                            FontWeight="Bold"
                            Style="{StaticResource RoundShadowButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>