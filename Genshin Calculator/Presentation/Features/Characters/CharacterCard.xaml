<UserControl x:Class="Genshin_Calculator.Presentation.Features.Characters.Components.CharacterCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:Genshin_Calculator.Presentation.Controls"

             xmlns:characters="clr-namespace:Genshin_Calculator.Presentation.Features.Characters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=characters:CharacterCardViewModel}"

             Width="380"
             MinWidth="350"
             MaxWidth="720"
             Margin="6">

    <UserControl.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          Color="Black"
                          Direction="270"
                          ShadowDepth="0"
                          BlurRadius="18"
                          Opacity="0.45" />

        <DropShadowEffect x:Key="RarityGlowEffect"
                          Color="#C8A865"
                          Direction="270"
                          ShadowDepth="0"
                          BlurRadius="14"
                          Opacity="0.50" />

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CBBFA9" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Typography.Capitals" Value="AllSmallCaps" />
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PillStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#1F2228" />
            <Setter Property="BorderBrush" Value="#343840" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="4,0" />
        </Style>

        <Style x:Key="TalentDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="6,0" />
            <Setter Property="Background" Value="#2A2D34" />
        </Style>
    </UserControl.Resources>

    <Grid Effect="{StaticResource CardShadow}">

        <Border x:Name="Root"
                CornerRadius="16"
                BorderThickness="1"
                Background="#181A1F"
                Margin="1">

            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#3A3D46" Offset="0" />
                    <GradientStop Color="#1C1E24" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        CornerRadius="16,16,0,0"
                        Background="{Binding Character.Assets.Rarity, Converter={StaticResource RarityToBrushConverter}}">
                    <Grid Margin="10,9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding EditCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    Margin="0,0,8,0">
                                <materialDesign:PackIcon Kind="PencilOutline" Width="20" Height="20" />
                            </Button>
                            <Button Command="{Binding AscendCommand}"
                                    Style="{StaticResource IconButtonStyle}">
                                <materialDesign:PackIcon Kind="StarOutline" Width="20" Height="20" />
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name, FallbackValue=Title}"
                                       HorizontalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding ToggleActiveCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    Margin="0,0,8,0">
                                <materialDesign:PackIcon Kind="Power" Width="20" Height="20" />
                            </Button>
                            <Button Command="{Binding RemoveCommand}"
                                    Style="{StaticResource IconButtonStyle}">
                                <materialDesign:PackIcon Kind="DeleteOutline" Width="20" Height="20" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="0"
                        Height="1"
                        VerticalAlignment="Bottom"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00C8A865" Offset="0" />
                            <GradientStop Color="#90C8A865" Offset="0.5" />
                            <GradientStop Color="#00C8A865" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Main content -->
                <Grid Grid.Row="1" Margin="12,12,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="104" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Portrait -->
                    <Grid Width="104" Height="104" ClipToBounds="False">
                        <Border Background="{Binding Assets.Rarity, Converter={StaticResource RarityToBrushConverter}}"
                                CornerRadius="14"
                                Effect="{StaticResource RarityGlowEffect}" />
                        
                        <Border CornerRadius="14"
                                Margin="3"
                                ClipToBounds="True">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding Assets.ImagePath}"
                                    Stretch="UniformToFill"
                                    RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border.Background>
                        </Border>
                        <Border IsHitTestVisible="False" CornerRadius="14">
                            <Border.Background>
                                <RadialGradientBrush GradientOrigin="0.5,0.5"
                                                                                 Center="0.5,0.5"
                                                                                 RadiusX="0.75" RadiusY="0.75">
                                    <GradientStop Color="#00000000" Offset="0.5" />
                                    <GradientStop Color="#55000000" Offset="1.0" />
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <!-- Stats -->
                    <Border Grid.Column="1"
                            Style="{StaticResource PillStyle}"
                            Margin="12,2,0,0"
                            VerticalAlignment="Center">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Column headings -->
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="Current"
                                       Style="{StaticResource InfoLabelStyle}"
                                       Margin="0,0,0,2" />
                            <TextBlock Grid.Row="0" Grid.Column="3"
                                       Text="Target"
                                       Style="{StaticResource InfoLabelStyle}"
                                       Margin="0,0,0,2" />

                            <!-- Character level -->
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding CurrentLevel, FallbackValue=1}"
                                       Style="{StaticResource InfoValueStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="2"
                                       Text="→"
                                       Foreground="#6B6659" FontSize="13"
                                       VerticalAlignment="Center" Margin="6,0" />
                            <TextBlock Grid.Row="1" Grid.Column="3"
                                       Text="{Binding DesiredLevel, FallbackValue=90}"
                                       Style="{StaticResource InfoValueStyle}"
                                       HorizontalAlignment="Center"
                                       Foreground="#C8A865" />

                            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                                    Style="{StaticResource TalentDividerStyle}"
                                    Margin="0,6,0,0" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4"
                                       Text="Talents"
                                       Style="{StaticResource InfoLabelStyle}"
                                       Margin="0,4,0,4" />

                            <!-- Auto Attack -->
                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="Attack"
                                       Foreground="#7A8FA8"
                                       FontSize="10" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Typography.Capitals="AllSmallCaps" />
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="{Binding AutoAttack.CurrentLevel, FallbackValue=1}"
                                       Style="{StaticResource InfoValueStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Grid.Row="4" Grid.Column="2"
                                       Text="→"
                                       Foreground="#6B6659" FontSize="13"
                                       VerticalAlignment="Center" Margin="6,0" />
                            <TextBlock Grid.Row="4" Grid.Column="3"
                                       Text="{Binding AutoAttack.DesiredLevel, FallbackValue=10}"
                                       Style="{StaticResource InfoValueStyle}"
                                       HorizontalAlignment="Center"
                                       Foreground="#C8A865" />

                            <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4"
                                    Style="{StaticResource TalentDividerStyle}" Margin="0,4" />

                            <!-- Elemental Skill -->
                            <TextBlock Grid.Row="6" Grid.Column="0"
                                       Text="Skill"
                                       Foreground="#7A8FA8"
                                       FontSize="10" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Typography.Capitals="AllSmallCaps" />
                            <TextBlock Grid.Row="6" Grid.Column="1"
                                       Text="{Binding Elemental.CurrentLevel, FallbackValue=1}"
                                       Style="{StaticResource InfoValueStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Grid.Row="6" Grid.Column="2"
                                       Text="→"
                                       Foreground="#6B6659" FontSize="13"
                                       VerticalAlignment="Center" Margin="6,0" />
                            <TextBlock Grid.Row="6" Grid.Column="3"
                                       Text="{Binding Elemental.DesiredLevel, FallbackValue=10}"
                                       Style="{StaticResource InfoValueStyle}"
                                       HorizontalAlignment="Center"
                                       Foreground="#C8A865" />

                            <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="4"
                                    Style="{StaticResource TalentDividerStyle}" Margin="0,4" />

                            <!-- Burst -->
                            <TextBlock Grid.Row="8" Grid.Column="0"
                                       Text="Burst"
                                       Foreground="#7A8FA8"
                                       FontSize="10" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Typography.Capitals="AllSmallCaps" />
                            <TextBlock Grid.Row="8" Grid.Column="1"
                                       Text="{Binding Burst.CurrentLevel, FallbackValue=1}"
                                       Style="{StaticResource InfoValueStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Grid.Row="8" Grid.Column="2"
                                       Text="→"
                                       Foreground="#6B6659" FontSize="13"
                                       VerticalAlignment="Center" Margin="6,0" />
                            <TextBlock Grid.Row="8" Grid.Column="3"
                                       Text="{Binding Burst.DesiredLevel, FallbackValue=10}"
                                       Style="{StaticResource InfoValueStyle}"
                                       HorizontalAlignment="Center"
                                       Foreground="#C8A865" />
                        </Grid>
                    </Border>

                </Grid>

                <!-- Resources -->
                <Border Grid.Row="2"
                        Margin="12,0,12,12"
                        CornerRadius="14"
                        Background="#20232A"
                        BorderBrush="#2D3139"
                        BorderThickness="1"
                        Padding="8"
                        Visibility="{Binding HasItems, ElementName=MaterialsList,
                                     Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl x:Name="MaterialsList"
                                  ItemsSource="{Binding RequiredMaterials}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:MaterialRequirementControl Margin="4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </Grid>
        </Border>

        <!-- Inactive overlay -->
        <Border Panel.ZIndex="1000"
                Background="#88000000"
                CornerRadius="16"
                IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActivated}" Value="False">
                            <Setter Property="Opacity" Value="1" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
    </Grid>
</UserControl>