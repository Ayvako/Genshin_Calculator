<Window x:Class="Genshin_Calculator.Presentation.Features.Inventory.InventoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Genshin_Calculator.Presentation.Helpers"
        xmlns:inventory="clr-namespace:Genshin_Calculator.Presentation.Features.Inventory"
        xmlns:converters="clr-namespace:Genshin_Calculator.Presentation.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"

    d:DataContext="{d:DesignInstance Type=inventory:InventoryViewModel}"
        Title="Inventory Manager"
        Height="780"
        Width="1060"
        MinHeight="650"
        MinWidth="880"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="#0D0E14"
        FontFamily="Segoe UI"
        TextElement.Foreground="#EAE6D8">

    <Window.Resources>

        <!-- ═══ Brushes ═══ -->
        <LinearGradientBrush x:Key="WindowBgBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0D0E14" Offset="0" />
            <GradientStop Color="#111318" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1A1C24" Offset="0" />
            <GradientStop Color="#14151C" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="HeaderGoldBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#C8A84B" Offset="0" />
            <GradientStop Color="#E8D07A" Offset="0.5" />
            <GradientStop Color="#C8A84B" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SaveBtnBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3A8C5C" Offset="0" />
            <GradientStop Color="#4DB87A" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CancelBtnBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8C3A3A" Offset="0" />
            <GradientStop Color="#C05050" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardTopLightBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="White" Offset="0" />
            <GradientStop Color="Transparent" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="GoldAccentBrush" Color="#C8A84B" />
        <SolidColorBrush x:Key="GoldSubtleBrush" Color="#4A3D1A" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#2E3140" />
        <SolidColorBrush x:Key="InputBgBrush" Color="#1E2030" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8A8FA8" />

        <!-- ═══ Typography ═══ -->
        <Style x:Key="WindowTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource HeaderGoldBrush}" />
        </Style>

        <Style x:Key="WindowSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Margin"     Value="0,2,0,0" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D4B86A" />
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- ═══ Cards ═══ -->
        <Style x:Key="InventoryCardStyle" TargetType="Border">
            <Setter Property="CornerRadius"   Value="10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush"    Value="{StaticResource CardBorderBrush}" />
            <Setter Property="Background"     Value="#2A2D3A" />
            <Setter Property="Margin"         Value="5" />
        </Style>

        <!-- ═══ Amount TextBox ═══ -->
        <Style x:Key="AmountBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground"               Value="#FEFEFE" />
            <Setter Property="Background"               Value="Transparent" />
            <Setter Property="BorderThickness"          Value="0" />
            <Setter Property="FontSize"                 Value="13" />
            <Setter Property="FontWeight"               Value="Bold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment"   Value="Center" />
            <Setter Property="Padding"                  Value="0" />
            <Setter Property="CaretBrush"               Value="#C8A84B" />
        </Style>

        <!-- ═══ Search TextBox ═══ -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground"      Value="#D0D4E0" />
            <Setter Property="Background"      Value="{StaticResource InputBgBrush}" />
            <Setter Property="BorderBrush"     Value="#2E3140" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Padding"         Value="12,8" />
            <Setter Property="CaretBrush"      Value="#C8A84B" />
            <Setter Property="SelectionBrush"  Value="#4A3D1A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#C8A84B" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5A5E70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Scrollbar ═══ -->
        <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="4" Background="#3A3E55" Margin="2,0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Action Buttons ═══ -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground"      Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.7" />
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" CenterX="60" CenterY="20" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Divider ═══ -->
        <Style x:Key="GoldDividerStyle" TargetType="Rectangle">
            <Setter Property="Height" Value="1" />
            <Setter Property="Fill"   Value="{StaticResource HeaderGoldBrush}" />
            <Setter Property="Margin" Value="0,10,0,14" />
            <Setter Property="Opacity" Value="0.5" />
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════
         ROOT
    ════════════════════════════════════════ -->
    <Grid Background="{StaticResource WindowBgBrush}">

        <!-- Outer glow border -->
        <Border Margin="14"
                CornerRadius="16"
                BorderBrush="#2A2E40"
                BorderThickness="1"
                Background="{StaticResource PanelBrush}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- Header  -->
                    <RowDefinition Height="Auto" />
                    <!-- Divider -->
                    <RowDefinition Height="Auto" />
                    <!-- Toolbar -->
                    <RowDefinition Height="*" />
                    <!-- Content -->
                    <RowDefinition Height="Auto" />
                    <!-- Footer  -->
                </Grid.RowDefinitions>

                <!-- ── HEADER ── -->
                <Grid Grid.Row="0" Margin="22,20,22,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Title block -->
                    <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#C8A84B" Offset="0" />
                                        <GradientStop Color="#E8D07A" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.RenderTransform>
                                    <RotateTransform Angle="45" CenterX="14" CenterY="14" />
                                </Border.RenderTransform>
                            </Border>
                            <TextBlock Text="INVENTORY" Style="{StaticResource WindowTitleStyle}" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1"
                        Command="{Binding CancelCommand}"
                        Width="40"
                        Height="40"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Background="{StaticResource CancelBtnBrush}"
                        Style="{StaticResource ActionButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✖"  FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- ── GOLD DIVIDER ── -->
                <Rectangle Grid.Row="1" Style="{StaticResource GoldDividerStyle}" Margin="22,12,22,0" />

                <!-- ── TOOLBAR: Search + Filter ── -->
                <Grid Grid.Row="2" Margin="22,0,22,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <!-- Filter ComboBox -->
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding FilterOptions}"
                              SelectedItem="{Binding SelectedFilter}"
                              VerticalAlignment="Center"
                              Padding="12,8"
                              Background="{StaticResource InputBgBrush}"
                              Foreground="#D0D4E0"
                              BorderBrush="#2E3140"
                              BorderThickness="1"
                              Style="{StaticResource ComboBoxStyle}"
                              ItemContainerStyle="{StaticResource ComboBoxItemStyle}" />
                </Grid>

                <!-- ── CONTENT: Material Cards ── -->

                <ListView Grid.Row="3"
                        ItemsSource="{Binding MaterialsView}"
                        BorderThickness="0"
                        Background="Transparent"
                        Padding="16,0,16,0"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.CanContentScroll="True"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                        VirtualizingPanel.ScrollUnit="Pixel"
                        VirtualizingPanel.VirtualizationMode="Recycling">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <vwp:VirtualizingWrapPanel
                                VirtualizingPanel.CacheLength="1,1"
                                VirtualizingPanel.CacheLengthUnit="Page" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>

                    <!-- Group headers -->
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="{x:Type GroupItem}">
                                    <Setter Property="Margin" Value="0,0,0,16" />
                                </Style>
                            </GroupStyle.ContainerStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Margin="6,10,6,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Gold left accent bar -->
                                        <Border Grid.Column="0"
                                                    Width="3"
                                                    CornerRadius="2"
                                                    Margin="0,0,10,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#E8D07A" Offset="0" />
                                                    <GradientStop Color="#6A5018" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource SectionTitleStyle}" />
                                            <Rectangle Height="1" Fill="#2E3140" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>

                    <!-- Item template -->
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource InventoryCardStyle}"
                                        Width="80"
                                        Height="108"
                                        Background="{Binding Rarity, Converter={StaticResource RarityToBrushConverter}}"
                                        ToolTipService.InitialShowDelay="150"
                                        ToolTipService.ShowDuration="60000">

                                <!-- Tooltip -->
                                <Border.ToolTip>
                                    <ToolTip Placement="Mouse"
                                                 Background="Transparent"
                                                 BorderThickness="0">
                                        <Border Width="230"
                                                    Padding="14"
                                                    CornerRadius="12"
                                                    Background="#16182A"
                                                    BorderBrush="#3A3E55"
                                                    BorderThickness="1">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.8" Color="Black" />
                                            </Border.Effect>
                                            <StackPanel>
                                                <!-- Name header -->
                                                <Border CornerRadius="8"
                                                            Padding="8"
                                                            Margin="0,0,0,10"
                                                            Background="{Binding Rarity, Converter={StaticResource RarityToBrushConverter}}">
                                                    <TextBlock Text="{Binding Name}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap" />
                                                </Border>

                                                <!-- Quantity row -->
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Quantity"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12" VerticalAlignment="Center" />
                                                    <Rectangle Grid.Column="1" Height="1" Fill="#2A2E40"
                                                                   Margin="8,0" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Amount}"
                                                                   Foreground="#E8D07A"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13" VerticalAlignment="Center" />
                                                </Grid>

                                                <!-- Rarity row -->
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Rarity"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12" VerticalAlignment="Center" />
                                                    <Rectangle Grid.Column="1" Height="1" Fill="#2A2E40"
                                                                   Margin="8,0" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Rarity}"
                                                                   Foreground="#E8D07A"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13" VerticalAlignment="Center" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </ToolTip>
                                </Border.ToolTip>

                                <!-- Card body -->
                                <Grid>
                                    <!-- Subtle inner top-light effect -->
                                    <Border VerticalAlignment="Top"
                                                CornerRadius="10,10,0,0"
                                                Height="30"
                                                Opacity="0.18"
                                                Background="{StaticResource CardTopLightBrush}">

                                    </Border>

                                    <!-- Item image -->
                                    <Image Source="{Binding ImagePath, Converter={StaticResource CachedImageConverter}}"
                                           Width="58"
                                           Height="58"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,10,0,0"
                                           RenderOptions.BitmapScalingMode="LowQuality">
                                    </Image>

                                    <!-- Amount input -->
                                    <Border VerticalAlignment="Bottom"
                                                Margin="8,0,8,8"
                                                CornerRadius="6"
                                                Padding="4,3">
                                        <Border.Background>
                                            <SolidColorBrush Color="#000000" Opacity="0.55" />
                                        </Border.Background>
                                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                                     helpers:TextBoxExtensions.NumericOnly="True"
                                                     Style="{StaticResource AmountBoxStyle}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- ── FOOTER ── -->
                <Border Grid.Row="4"
                    BorderBrush="#22253A"
                    BorderThickness="0,1,0,0"
                    Margin="0,12,0,0"
                    Padding="22,14,22,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Buttons -->
                        <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                            <Button Command="{Binding SaveCommand}"
                                Width="130"
                                Height="40"
                                Background="{StaticResource SaveBtnBrush}"
                                Padding="14,0"
                                Style="{StaticResource ActionButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✔"  FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Сохранить" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>