<Window x:Class="Genshin_Calculator.Presentation.Views.InventoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Genshin_Calculator.Presentation.ViewModels"
        xmlns:converters="clr-namespace:Genshin_Calculator.Helpers.Converters"
        mc:Ignorable="d"
        Title="Inventory Manager" Height="600" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#222222">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Инвентарь" Foreground="White" FontSize="20" FontWeight="Bold" Margin="10,0,0,10" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding MaterialsView}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                   Foreground="#FFD700"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="10,15,0,5" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ItemsControl.GroupStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="4"
                        Width="65"
                        CornerRadius="10"
                        BorderBrush="Black"
                        BorderThickness="1"
                        Background="{Binding Rarity, Converter={StaticResource RarityToBrushConverter}}">

                            <StackPanel Orientation="Vertical">

                                <Image Source="{Binding ImagePath}"
                                    Width="40"
                                    Height="40"
                                    Margin="0,5"
                                    ToolTip="{Binding Name}"
                                    RenderOptions.BitmapScalingMode="HighQuality" />

                                <Border Background="Black" CornerRadius="9,9,0,0">
                                    <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="White"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextAlignment="Center"
                                     FontSize="11"
                                     FontWeight="Bold"
                                     CaretBrush="White" />
                                </Border>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="80" Height="30" Margin="5" />
            <Button Content="Сохранить" Command="{Binding SaveCommand}" Width="100" Height="30" Background="#2E7D32" Foreground="White" Margin="5" />
        </StackPanel>
    </Grid>

</Window>