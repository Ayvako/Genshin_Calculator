<Window x:Class="Genshin_Calculator.Presentation.Features.Characters.CharacterEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:charFeatures="clr-namespace:Genshin_Calculator.Presentation.Features.Characters.Components"

        Width="350"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="14,14,0,0" Padding="0" Background="{StaticResource MyGradientBrush}">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Header -->
                <RowDefinition Height="Auto" />
                <!-- Content -->
                <RowDefinition Height="Auto" />
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseLeftButtonDown="OnMouseLeftButtonDown"
                Background="{Binding Editable.Assets.Rarity, Converter={StaticResource RarityToBrushConverter}}">

                <TextBlock Text="{Binding Editable.Name, FallbackValue='Name'}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 12"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White" />
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="10,10,10,0">

                <!-- Level -->
                <StackPanel>
                    <TextBlock Text="Lv."
                           Foreground="#EED18C"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0 0 0 10"
                           HorizontalAlignment="Center" />
                    <UniformGrid Columns="2">
                        <charFeatures:LevelSelectorControl Title="Current"
                                                  Level="{Binding Editable.CurrentLevel}"
                                                  LevelOptionsPairs="{Binding LevelOptionsPairs}" />
                        <charFeatures:LevelSelectorControl Title="Desired"
                                                  Level="{Binding Editable.DesiredLevel}"
                                                  LevelOptionsPairs="{Binding LevelOptionsPairs}" />
                    </UniformGrid>
                    <Rectangle Height="1" Fill="#C4B8A8" Margin="0,10" />
                </StackPanel>

                <!-- Talents -->
                <ItemsControl ItemsSource="{Binding Talents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                       Foreground="#EED18C"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0 0 0 10"
                                       HorizontalAlignment="Center" />
                                <UniformGrid Columns="2">
                                    <charFeatures:TalentLevelControl Title="Current" Level="{Binding CurrentLevel}" />
                                    <charFeatures:TalentLevelControl Title="Desired" Level="{Binding DesiredLevel}" />
                                </UniformGrid>
                                <Rectangle Height="1" Fill="#C4B8A8" Margin="0,10" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,10">

                <Button Content="✖"
                       Style="{StaticResource RoundShadowButtonStyle}"
                       Margin="0,0,25,0"
                       Background="#C84646"
                       Foreground="White"
                       Command="{Binding CancelCommand}"
                       IsCancel="True" />
                <Button Content="✔"
                       Style="{StaticResource RoundShadowButtonStyle}"
                       Margin="25,0,0,0"
                       Background="#419D5F"
                       Foreground="White"
                       Command="{Binding SaveCommand}"
                       IsDefault="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>