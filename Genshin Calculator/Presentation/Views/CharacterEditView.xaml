<Window x:Class="Genshin_Calculator.Presentation.Views.CharacterEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Genshin_Calculator.Presentation.ViewModels"
        xmlns:controls="clr-namespace:Genshin_Calculator.Presentation.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:CharacterEditViewModel}"
        Width="350"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="14,14,0,0" Padding="0" Background="{StaticResource MyGradientBrush}">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Header -->
                <RowDefinition Height="Auto" />
                <!-- Content -->
                <RowDefinition Height="Auto" />
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0"
                Background="{Binding Editable.Assets.Rarity, Converter={StaticResource RarityToBrushConverter}}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                              Command="{Binding DragWindowCommand}"
                              CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
                </Border.InputBindings>

                <TextBlock Text="{Binding Editable.Name, FallbackValue='Name'}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 12"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White" />
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="10,10,10,0">

                <!-- Level -->
                <StackPanel>
                    <TextBlock Text="Lv."
                           Foreground="#EED18C"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0 0 0 10"
                           HorizontalAlignment="Center" />
                    <UniformGrid Columns="2">
                        <controls:LevelSelectorControl Title="Current"
                                                  Level="{Binding Editable.CurrentLevel}"
                                                  LevelOptionsPairs="{Binding LevelOptionsPairs}" />
                        <controls:LevelSelectorControl Title="Desired"
                                                  Level="{Binding Editable.DesiredLevel}"
                                                  LevelOptionsPairs="{Binding LevelOptionsPairs}" />
                    </UniformGrid>
                    <Rectangle Height="1" Fill="#C4B8A8" Margin="0,10" />
                </StackPanel>

                <!-- Talents -->
                <ItemsControl ItemsSource="{Binding Talents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                       Foreground="#EED18C"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0 0 0 10"
                                       HorizontalAlignment="Center" />
                                <UniformGrid Columns="2">
                                    <controls:TalentLevelControl Title="Current" Level="{Binding CurrentLevel}" />
                                    <controls:TalentLevelControl Title="Desired" Level="{Binding DesiredLevel}" />
                                </UniformGrid>
                                <Rectangle Height="1" Fill="#C4B8A8" Margin="0,10" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,10">
                <Button Content="✖" Width="48" Height="48" FontSize="22" Margin="0,0,25,0"
                    Background="#C84646" Foreground="White"
                    Command="{Binding CancelCommand}" />
                <Button Content="✔" Width="48" Height="48" FontSize="22" Margin="25,0,0,0"
                    Background="#419D5F" Foreground="White"
                    Command="{Binding SaveCommand}" />
            </StackPanel>

        </Grid>
    </Border>
</Window>