<UserControl x:Class="Genshin_Calculator.Presentation.Features.Characters.Components.TalentLevelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:сomponents="clr-namespace:Genshin_Calculator.Presentation.Features.Characters.Components"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=сomponents:TalentLevelControl}"

             x:Name="root">

    <UserControl.Resources>
        <Style x:Key="LevelActionButtonStyle"
               BasedOn="{StaticResource RoundedButtonStyle}"
               TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </UserControl.Resources>

    <StackPanel HorizontalAlignment="Center">

        <TextBlock Text="{Binding Title, ElementName=root}"
                   Foreground="#AAA"
                   FontSize="12"
                   Margin="0,0,0,4"
                   HorizontalAlignment="Center" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

            <Button Style="{StaticResource LevelActionButtonStyle}"
                    Command="{Binding DecreaseLevelCommand, ElementName=root}"
                    IsEnabled="{Binding Level, ElementName=root, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}">
                <TextBlock Text="-" Margin="0,-8,0,0" FontSize="28" />
            </Button>

            <Border CornerRadius="2"
                    Background="#E8E2D4"
                    BorderBrush="#D4C8B8"
                    BorderThickness="1"
                    Width="35"
                    Height="30">

                <TextBlock Text="{Binding Level, ElementName=root}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#2C2C2C"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <Button Style="{StaticResource LevelActionButtonStyle}"
                    Command="{Binding IncreaseLevelCommand, ElementName=root}"
                    IsEnabled="{Binding Level, ElementName=root, Converter={StaticResource LevelLessThanConverter}, ConverterParameter=10}">
                <TextBlock Text="+" Margin="0,-8,0,0" FontSize="28" />
            </Button>

        </StackPanel>
    </StackPanel>
</UserControl>