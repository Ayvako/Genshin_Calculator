<UserControl x:Class="Genshin_Calculator.Presentation.Features.Characters.Components.CharacterCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:Genshin_Calculator.Presentation.Controls"
             xmlns:characters="clr-namespace:Genshin_Calculator.Presentation.Features.Characters"

             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=characters:CharacterCardViewModel}"

             Width="380"
             MinWidth="350"
             MaxWidth="720"
             Margin="6">

    <UserControl.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          Color="Black"
                          Direction="270"
                          ShadowDepth="0"
                          BlurRadius="18"
                          Opacity="0.45" />

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CBBFA9" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PillStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#1F2228" />
            <Setter Property="BorderBrush" Value="#343840" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="4,0" />
        </Style>
    </UserControl.Resources>
    <Grid ClipToBounds="True">

        <Border x:Name="Root"
            CornerRadius="16"
            BorderBrush="#24262C"
            BorderThickness="1"
            Background="#181A1F"
            Margin="1"
            Effect="{StaticResource CardShadow}">

            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                    CornerRadius="16,16,0,0"
                    Background="{Binding Character.Assets.Rarity, Converter={StaticResource RarityToBrushConverter}}">

                    <Grid Margin="10,9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding EditCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                Margin="0,0,8,0">
                                <materialDesign:PackIcon Kind="PencilOutline" Width="20" Height="20" />
                            </Button>

                            <Button Command="{Binding AscendCommand}"
                                Style="{StaticResource IconButtonStyle}">
                                <materialDesign:PackIcon Kind="StarOutline" Width="20" Height="20" />
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name, FallbackValue=Title}"
                                   HorizontalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding ToggleActiveCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                Margin="0,0,8,0">
                                <materialDesign:PackIcon Kind="Power" Width="20" Height="20" />
                            </Button>

                            <Button Command="{Binding RemoveCommand}"
                                Style="{StaticResource IconButtonStyle}">
                                <materialDesign:PackIcon Kind="DeleteOutline" Width="20" Height="20" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main content -->
                <Grid Grid.Row="1" Margin="12,12,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="104" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Character image -->
                    <Grid Width="104" Height="104" ClipToBounds="True">
                        <Border Background="{Binding Assets.Rarity, Converter={StaticResource RarityToBrushConverter}}"
                            CornerRadius="14" />
                        <Border CornerRadius="14"
                            Margin="3"
                            Background="#22111111"
                            ClipToBounds="True">
                            <Image Source="{Binding Assets.ImagePath}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                    </Grid>

                    <!-- Stats -->
                    <StackPanel Grid.Column="1"
                            Margin="12,2,0,0"
                            VerticalAlignment="Center">

                        <Border Style="{StaticResource PillStyle}">
                            <StackPanel>
                                <TextBlock Text="Levels" Style="{StaticResource InfoLabelStyle}" />
                                <TextBlock Style="{StaticResource InfoValueStyle}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} → {1}">
                                            <Binding Path="CurrentLevel" FallbackValue="1" />
                                            <Binding Path="DesiredLevel" FallbackValue="90" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PillStyle}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Talents" Style="{StaticResource InfoLabelStyle}" />
                                <TextBlock Style="{StaticResource InfoValueStyle}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} → {1}&#x0a;{2} → {3}&#x0a;{4} → {5}">
                                            <Binding Path="AutoAttack.CurrentLevel" FallbackValue="1" />
                                            <Binding Path="AutoAttack.DesiredLevel" FallbackValue="10" />
                                            <Binding Path="Elemental.CurrentLevel" FallbackValue="1" />
                                            <Binding Path="Elemental.DesiredLevel" FallbackValue="10" />
                                            <Binding Path="Burst.CurrentLevel" FallbackValue="1" />
                                            <Binding Path="Burst.DesiredLevel" FallbackValue="10" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Resources -->
                <Border Grid.Row="2"
                    Margin="12,0,12,12"
                    CornerRadius="14"
                    Background="#20232A"
                    BorderBrush="#2D3139"
                    BorderThickness="1"
                    Padding="8">
                    <ItemsControl ItemsSource="{Binding RequiredMaterials}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:MaterialRequirementControl Margin="4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </Grid>
        </Border>
        <Border Panel.ZIndex="1000"
            Background="#88000000"
            CornerRadius="16"
            IsHitTestVisible="False">

            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActivated}" Value="False">
                            <Setter Property="Opacity" Value="1" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

        </Border>
    </Grid>
</UserControl>