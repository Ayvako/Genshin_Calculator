<UserControl x:Class="Genshin_Calculator.Presentation.Controls.TalentLevelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">

    <StackPanel HorizontalAlignment="Center">

        <TextBlock Text="{Binding Title, ElementName=root, FallbackValue=Title}"
                   Foreground="#AAA" FontSize="12"
                   Margin="0 0 0 4"
                   HorizontalAlignment="Center" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

            <Button Width="30" Height="30" Padding="0"
                    Style="{StaticResource RoundedButtonStyle}"
                    Command="{Binding DecreaseLevelCommand, ElementName=root}"
                    IsEnabled="{Binding Level, ElementName=root, Converter={StaticResource LevelGreaterThanOneConverter}}">
                <TextBlock Text="-" Margin="0,-8,0,0" FontSize="28" />
            </Button>

            <Border CornerRadius="2"
                    Background="#E8E2D4"
                    BorderBrush="#D4C8B8"
                    BorderThickness="1" Width="35" Height="30">

                <TextBlock Text="{Binding Level, ElementName=root, FallbackValue=10}"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="#2C2C2C"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     PreviewTextInput="NumberValidation" />
            </Border>

            <Button Width="30" Height="30" Padding="0"
                    Style="{StaticResource RoundedButtonStyle}"
                    Command="{Binding IncreaseLevelCommand, ElementName=root}"
                    IsEnabled="{Binding Level, ElementName=root, Converter={StaticResource LevelLessThanConverter}, ConverterParameter=10}">
                <TextBlock Text="+" Margin="0,-8,0,0" FontSize="28" />
            </Button>

        </StackPanel>
    </StackPanel>
</UserControl>