<Window x:Class="Genshin_Calculator.Presentation.Features.Dialogs.UpgradeCharacterDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:Genshin_Calculator.Presentation.Controls"
        Height="500" Width="450"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E" Foreground="White">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Character.Name, StringFormat='Upgrade {0}'}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
            <ItemsControl ItemsSource="{Binding Materials}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2D2D2D" Margin="0,2" Padding="4" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <components:MaterialRequirementControl Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TargetMaterial.Name}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />

                                    <ItemsControl ItemsSource="{Binding AlchemyCosts}" Margin="0,2,0,0"
                                                  Visibility="{Binding AlchemyCosts.Count, Converter={StaticResource IntToVisibilityConverter}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,8,2" ToolTip="{Binding Name}">
                                                    <Border Width="16" Height="16" CornerRadius="3"
                                                            BorderBrush="Black" BorderThickness="1"
                                                            Background="{Binding Rarity, Converter={StaticResource RarityToBrushConverter}}">
                                                        <Image Source="{Binding ImagePath}" Stretch="Uniform" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Amount, StringFormat='x{0}'}" Margin="2,0,0,0" FontSize="11" Foreground="#87CEFA" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="5,0,0,0">
                                    <TextBlock Text="{Binding TotalRequired, StringFormat='Нужно: {0}'}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="13" />
                                    <TextBlock Text="{Binding CraftedAmount, StringFormat='+ {0} (крафт)'}"
                                               FontSize="11" Foreground="#87CEFA" HorizontalAlignment="Right" Margin="0,1,0,0"
                                               Visibility="{Binding CraftedAmount, Converter={StaticResource IntToVisibilityConverter}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="✖" Style="{StaticResource RoundShadowButtonStyle}"
                    Margin="0,0,15,0" Width="30" Height="30"
                    Background="#C84646" Foreground="White"
                    Command="{Binding CancelCommand}" IsCancel="True" />

            <Button Content="✔" Style="{StaticResource RoundShadowButtonStyle}"
                    Margin="15,0,0,0" Width="30" Height="30"
                    Background="#419D5F" Foreground="White"
                    Command="{Binding SaveCommand}" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>