<Window x:Class="Genshin_Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Genshin_Calculator.Views"

        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#31394E" Offset="0" />
            <GradientStop Color="#1D212D" Offset="0.2" />
            <GradientStop Color="#191E33" Offset="0.4" />
            <GradientStop Color="#141829" Offset="0.6" />
            <GradientStop Color="#101321" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>
</Window>