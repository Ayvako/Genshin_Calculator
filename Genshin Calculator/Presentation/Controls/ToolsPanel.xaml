<UserControl x:Class="Genshin_Calculator.Presentation.Controls.ToolsPanelControl"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ToolsPanelViewModel, IsDesignTimeCreatable=False}"
             xmlns:vm="clr-namespace:Genshin_Calculator.Presentation.ViewModels">

    <Grid>
        <WrapPanel HorizontalAlignment="Center" Margin="10">
            <Button Content="Add Character" Padding="0"
                    Width="150"
                    Height="35"
                    Style="{StaticResource RoundedButtonStyle}"
                    Command="{Binding ShowCharacterSelectorCommand}" />

            <Button Content="Manage Inventory" Padding="0"
                    Width="150"
                    Height="35"
                    Style="{StaticResource RoundedButtonStyle}"
                    Command="{Binding ManageInventoryCommand}" />

            <Button Content="Manage Priority" Padding="0"
                    Width="150"
                    Height="35"
                    Style="{StaticResource RoundedButtonStyle}"
                    Command="{Binding ManagePriorityCommand}" />
        </WrapPanel>

    </Grid>
</UserControl>