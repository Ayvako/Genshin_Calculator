<Application x:Class="Genshin_Calculator.Presentation.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Genshin_Calculator.Presentation.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Presentation/Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:RarityToBrushConverter x:Key="RarityToBrushConverter" />

            <conv:LevelLessThanConverter x:Key="LevelLessThanConverter" />
            <conv:GreaterThanConverter x:Key="GreaterThanConverter" />

            <conv:ElementToIconConverter x:Key="ElementToIconConverter" />
            <conv:WeaponToIconConverter x:Key="WeaponToIconConverter" />

            <conv:ContainsConverter x:Key="ContainsConverter" />
            <conv:DimElementConverter x:Key="DimElementConverter" />

            <conv:IconProxyConverter x:Key="IconProxyConverter" />

            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>