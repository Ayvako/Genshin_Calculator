<UserControl x:Class="Genshin_Calculator.Presentation.Controls.CharacterCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Genshin_Calculator.Presentation.ViewModels"
             xmlns:local="clr-namespace:Genshin_Calculator.Presentation.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance Type=vm:CharacterCardViewModel, IsDesignTimeCreatable=False}"
             mc:Ignorable="d"
             Width="350" MinWidth="350" MaxWidth="712" Margin="5">

    <!-- Основная рамка карточки -->

    <Border x:Name="Root" CornerRadius="10" BorderBrush="Black" BorderThickness="1"  Margin="1" Background="{StaticResource MyGradientBrush}">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="0" ShadowDepth="0" BlurRadius="11" Opacity="0.75" />
        </Border.Effect>
        <Grid>

            <StackPanel>
                <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
                <Border
                CornerRadius="10,10,0,0"
                Background="{Binding Character.Assets.Rarity, Converter={StaticResource RarityToBrushConverter}}">

                    <Grid Margin="6">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Левая панель -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                Style="{StaticResource HoverButtonPanelStyle}">
                            <Button Command="{Binding EditCommand}" Style="{StaticResource IconButtonStyle}" Margin="0,0,10,0">
                                <materialDesign:PackIcon Kind="PencilOutline" Width="22" Height="22" />
                            </Button>

                            <Button Command="{Binding AscendCommand}" Style="{StaticResource IconButtonStyle}">
                                <materialDesign:PackIcon Kind="StarOutline" Width="22" Height="22" />
                            </Button>
                        </StackPanel>

                        <!-- Имя персонажа -->
                        <TextBlock Grid.Column="1"
                           Text="{Binding Name, FallbackValue=Title}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="#FFCCCCCC" />

                        <!-- Правая панель -->
                        <StackPanel Orientation="Horizontal" Grid.Column="2"
                                Style="{StaticResource HoverButtonPanelStyle}">

                            <Button Command="{Binding ToggleActiveCommand}" Style="{StaticResource IconButtonStyle}" Margin="0,0,10,0">
                                <materialDesign:PackIcon Kind="Power" Width="22" Height="22" />
                            </Button>
                            <Button Command="{Binding RemoveCommand}" Style="{StaticResource IconButtonStyle}">
                                <materialDesign:PackIcon Kind="DeleteOutline" Width="22" Height="22" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Панель информации -->
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="96" Height="96" ClipToBounds="True">
                        <Border Background="{Binding Assets.Rarity, Converter={StaticResource RarityToBrushConverter}}" CornerRadius="10" />
                        <Border CornerRadius="10" ClipToBounds="True">
                            <Image Source="{Binding Assets.ImagePath}"
                                                Stretch="UniformToFill" />
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="8" VerticalAlignment="Center">
                        <!-- Уровень -->
                        <StackPanel Orientation="Vertical" Margin="0,0,0,4">
                            <TextBlock Text="Levels" Foreground="#FFECE5D8" FontWeight="Bold" FontSize="14" TextAlignment="Center" />
                            <TextBlock Foreground="#FFCCCCCC" FontWeight="Bold" FontSize="14" TextAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} → {1}">
                                        <Binding Path="CurrentLevel" FallbackValue="1" />
                                        <Binding Path="DesiredLevel" FallbackValue="90" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <!-- Таланты -->
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Talents" Foreground="#FFECE5D8" FontWeight="Bold" FontSize="14" TextAlignment="Center" />
                            <TextBlock Foreground="#FFCCCCCC" FontWeight="Bold" FontSize="14" TextAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} → {1}&#x0a;{2} → {3}&#x0a;{4} → {5}">
                                        <Binding Path="AutoAttack.CurrentLevel" FallbackValue="1" />
                                        <Binding Path="AutoAttack.DesiredLevel" FallbackValue="10" />
                                        <Binding Path="Elemental.CurrentLevel" FallbackValue="1" />
                                        <Binding Path="Elemental.DesiredLevel" FallbackValue="1" />
                                        <Binding Path="Burst.CurrentLevel" FallbackValue="1" />
                                        <Binding Path="Burst.DesiredLevel" FallbackValue="1" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Панель ресурсов -->
                <ItemsControl ItemsSource="{Binding RequiredMaterials}" Margin="0,6,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.OpenAddItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Button.Template>

                                <Border Margin="4" CornerRadius="10" BorderBrush="Black" BorderThickness="1"
                                    Background="{Binding Rarity, Converter={StaticResource RarityToBrushConverter}}">
                                    <StackPanel Orientation="Vertical">
                                        <Border Background="Black" CornerRadius="10,10,0,0">
                                            <TextBlock Text="{Binding Amount}" Foreground="White" TextAlignment="Center" />
                                        </Border>
                                        <Image Source="{Binding ImagePath}" Width="40" Height="40" />
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

            <Rectangle x:Name="InactiveMask" Fill="Black" RadiusX="10" RadiusY="10" IsHitTestVisible="False">
                <Rectangle.Style>

                    <Style TargetType="Rectangle">
                        <Setter Property="Opacity" Value="0" />

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActivated}" Value="False">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0.5"
                                                 Duration="0:0:0.3" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>

                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.3" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>

                    </Style>
                </Rectangle.Style>
            </Rectangle>
        </Grid>

    </Border>

</UserControl>