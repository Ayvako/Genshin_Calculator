<Window x:Class="Genshin_Calculator.Presentation.Features.Characters.CharacterSelectorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:Genshin_Calculator.Presentation.Features.Characters.Components"
        xmlns:h="clr-namespace:Genshin_Calculator.Presentation.Helpers"
        xmlns:enums="clr-namespace:Genshin_Calculator.Core.Models.Enums"

        xmlns:characters="clr-namespace:Genshin_Calculator.Presentation.Features.Characters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=characters:CharacterSelectorViewModel}"

        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"

        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <DropShadowEffect x:Key="WindowShadow"
                          Color="Black" Direction="270"
                          ShadowDepth="6" BlurRadius="32" Opacity="0.7" />

        <DropShadowEffect x:Key="TileShadow"
                          Color="Black" Direction="270"
                          ShadowDepth="0" BlurRadius="18" Opacity="0.45" />

        <!-- ── Shared brushes ─────────────────────────────────── -->

        <!--  Vertical fade-in/out separator used between filter groups  -->
        <LinearGradientBrush x:Key="VerticalSeparatorBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#002A2D34" Offset="0" />
            <GradientStop Color="#FF2A2D34" Offset="0.3" />
            <GradientStop Color="#FF2A2D34" Offset="0.7" />
            <GradientStop Color="#002A2D34" Offset="1" />
        </LinearGradientBrush>

        <!--  Radial vignette overlaid on character portraits  -->
        <RadialGradientBrush x:Key="PortraitVignetteBrush"
                             GradientOrigin="0.5,0.5"
                             Center="0.5,0.5"
                             RadiusX="0.75" RadiusY="0.75">
            <GradientStop Color="#00000000" Offset="0.5" />
            <GradientStop Color="#55000000" Offset="1.0" />
        </RadialGradientBrush>

        <!-- ── ScrollBar ──────────────────────────────────────── -->

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3" Background="#3A3D48" Margin="2,0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── SearchBox ─────────────────────────────────────── -->

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground"      Value="#E8E0D0" />
            <Setter Property="CaretBrush"      Value="#C8A865" />
            <Setter Property="SelectionBrush"  Value="#4AC8A865" />
            <Setter Property="Background"      Value="#22252C" />
            <Setter Property="BorderBrush"     Value="#2D3139" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="12,7" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused"    Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#80C8A865" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#50C8A865" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Rarity ToggleButton ───────────────────────────── -->

        <Style x:Key="RarityToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width"      Value="36" />
            <Setter Property="Height"     Value="36" />
            <Setter Property="Margin"     Value="2,0" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="Focusable"  Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bg"
                                CornerRadius="8"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"   Value="#18C8A865" />
                                <Setter TargetName="Bg" Property="BorderBrush"  Value="#30C8A865" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background"   Value="#30C8A865" />
                                <Setter TargetName="Bg" Property="BorderBrush"  Value="#AAC8A865" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Character tile button ─────────────────────────── -->

        <Style x:Key="CharacterTileButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness"      Value="0" />
            <Setter Property="Padding"              Value="0" />
            <Setter Property="Cursor"               Value="Hand" />
            <Setter Property="Focusable"            Value="False" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                 To="1.06" Duration="0:0:0.15" />
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                 To="1.06" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                 To="1.0" Duration="0:0:0.12" />
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                 To="1.0" Duration="0:0:0.12" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>
    <Grid Margin="40">
        <Border CornerRadius="16"
            Background="#181A1F"
            Effect="{StaticResource WindowShadow}"
            BorderThickness="1">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#3A3D46" Offset="0" />
                    <GradientStop Color="#1C1E24" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid Width="720">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- Header окна    -->
                    <RowDefinition Height="Auto" />
                    <!-- Search + Sort  -->
                    <RowDefinition Height="Auto" />
                    <!-- Filters        -->
                    <RowDefinition Height="Auto" />
                    <!-- Separator      -->
                    <RowDefinition Height="Auto" />
                    <!-- Character grid -->
                </Grid.RowDefinitions>

                <!-- ── Header ────────────────────────────────────── -->
                <Grid Grid.Row="0">
                    <Border CornerRadius="16,16,0,0" Padding="18,13">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#22252C" Offset="0" />
                                <GradientStop Color="#181A1F" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <!--  Close button  -->
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Style="{StaticResource IconButtonStyle}"
                                Command="{Binding CancelCommand}">
                                <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                            </Button>
                        </Border>
                    </Border>

                    <Border Height="1" VerticalAlignment="Bottom" IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00C8A865" Offset="0" />
                                <GradientStop Color="#70C8A865" Offset="0.5" />
                                <GradientStop Color="#00C8A865" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <!-- ── Search + Sort ──────────────────────────────── -->
                <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,14,0,8">
                    <TextBox Width="220"
                         Style="{StaticResource SearchBoxStyle}"
                         h:TextBoxHelper.Placeholder="Search..."
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                    <ToggleButton IsChecked="{Binding IsSortByRarity}"
                              Style="{StaticResource SortToggleButtonStyle}"
                              Margin="10,0,0,0" />
                </StackPanel>

                <!-- ── Filters ────────────────────────────────────── -->
                <Border Grid.Row="2"
                    Margin="14,0,14,4"
                    CornerRadius="10"
                    Background="#20232A"
                    BorderBrush="#2D3139"
                    BorderThickness="1"
                    Padding="10,6">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,2,6,2">

                            <components:FilterToggleList
                            Items="{Binding ElementTypes}"
                            SelectedItems="{Binding SelectedElements}"
                            ToggleCommand="{Binding ToggleElementCommand}"
                            IconConverter="{StaticResource ElementToIconConverter}" />

                            <!--  Vertical separator  -->
                            <Border Width="1" Margin="8,4"
                                Background="{StaticResource VerticalSeparatorBrush}" />

                            <components:FilterToggleList
                            Items="{Binding WeaponTypes}"
                            SelectedItems="{Binding SelectedWeapons}"
                            ToggleCommand="{Binding ToggleWeaponCommand}"
                            IconConverter="{StaticResource WeaponToIconConverter}" />

                            <Border Width="1" Margin="8,4"
                                Background="{StaticResource VerticalSeparatorBrush}" />

                            <!-- ── Rarity filters ─────────────────── -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- 4★ purple -->
                                <ToggleButton Style="{StaticResource RarityToggleStyle}"
                                          Command="{Binding ToggleRarityCommand}"
                                          CommandParameter="{x:Static enums:MaterialRarity.Violet}"
                                          IsChecked="{Binding IsVioletRaritySelected, Mode=OneWay}">
                                    <Grid Width="22" Height="22">
                                        <Polygon Points="11,1 13.3,7.9 20.5,7.9 14.6,12.2 16.9,19 11,14.9 5.1,19 7.4,12.2 1.5,7.9 8.7,7.9"
                                             Stretch="Fill" Fill="#9B72CF" Opacity="0.25" />
                                        <Polygon Points="11,1 13.3,7.9 20.5,7.9 14.6,12.2 16.9,19 11,14.9 5.1,19 7.4,12.2 1.5,7.9 8.7,7.9"
                                             Stretch="Fill" Fill="#9B72CF" Stroke="#C4A0FF" StrokeThickness="0.5" />
                                    </Grid>
                                </ToggleButton>
                                <!-- 5★ gold -->
                                <ToggleButton Style="{StaticResource RarityToggleStyle}"
                                          Command="{Binding ToggleRarityCommand}"
                                          CommandParameter="{x:Static enums:MaterialRarity.Orange}"
                                          IsChecked="{Binding IsOrangeRaritySelected, Mode=OneWay}">
                                    <Grid Width="22" Height="22">
                                        <Polygon Points="11,1 13.3,7.9 20.5,7.9 14.6,12.2 16.9,19 11,14.9 5.1,19 7.4,12.2 1.5,7.9 8.7,7.9"
                                             Stretch="Fill" Fill="#C8A865" Opacity="0.25" />
                                        <Polygon Points="11,1 13.3,7.9 20.5,7.9 14.6,12.2 16.9,19 11,14.9 5.1,19 7.4,12.2 1.5,7.9 8.7,7.9"
                                             Stretch="Fill" Fill="#C8A865" Stroke="#EED18C" StrokeThickness="0.5" />
                                    </Grid>
                                </ToggleButton>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ── Character grid ─────────────────────────────── -->
                <ScrollViewer Grid.Row="4"
                          Height="420"
                          Margin="6,10,6,12"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly">

                    <ItemsControl ItemsSource="{Binding FilteredCharacters}"
                              HorizontalAlignment="Center">

                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="FrameworkElement.Margin" Value="5" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectCharacterCommand,
                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource CharacterTileButtonStyle}">

                                    <Border Width="96" ClipToBounds="True">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Name header -->
                                            <Border Grid.Row="0"
                                                CornerRadius="14,14,0,0"
                                                Padding="4,5"
                                                Background="{Binding Assets.Rarity,
                                                             Converter={StaticResource RarityToBrushConverter}}">
                                                <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center" />
                                            </Border>

                                            <!-- Portrait -->
                                            <Border Grid.Row="1"
                                                ClipToBounds="True"
                                                Height="96"
                                                CornerRadius="0,0,14,14">
                                                <Grid>
                                                    <!-- Rarity colour base -->
                                                    <Border Background="{Binding Assets.Rarity,
                                                                    Converter={StaticResource RarityToBrushConverter}}"
                                                        CornerRadius="0,0,14,14" />

                                                    <!-- Portrait image -->
                                                    <Border Margin="3" ClipToBounds="True" CornerRadius="0,0,14,14">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding Assets.ImagePath}"
                                                                    Stretch="UniformToFill"
                                                                    RenderOptions.BitmapScalingMode="HighQuality" />
                                                        </Border.Background>
                                                    </Border>

                                                    <!-- Vignette overlay -->
                                                    <Border IsHitTestVisible="False"
                                                        CornerRadius="0,0,14,14"
                                                        Background="{StaticResource PortraitVignetteBrush}" />
                                                </Grid>
                                            </Border>

                                        </Grid>
                                    </Border>

                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>