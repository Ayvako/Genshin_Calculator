<Window x:Class="Genshin_Calculator.Views.CharacterEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Genshin_Calculator.ViewModels"
        xmlns:controls="clr-namespace:Genshin_Calculator.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:CharacterEditViewModel}"
        Title="Edit Character"
        Width="350"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="14"
            Padding="0"
            Background="Transparent">

        <Border CornerRadius="14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#31394E" Offset="0" />
                    <GradientStop Color="#1D212D" Offset="0.2" />
                    <GradientStop Color="#191E33" Offset="0.4" />
                    <GradientStop Color="#141829" Offset="0.6" />
                    <GradientStop Color="#101321" Offset="0.8" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Character Name -->
                <Border Grid.Row="0" CornerRadius="14 14 0 0"
                        Background="{Binding Editable.Assets.Rarity, Converter={StaticResource RarityToBrushConverter}}"
                        MouseLeftButtonDown="TopBarMouseLeftButtonDown">
                    <TextBlock Text="{Binding Editable.Name, FallbackValue='Name'}"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 12"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="White" />
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border>
                            <StackPanel>
                                <TextBlock Text="Lv."
                                   Foreground="#EED18C"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0 0 0 10" HorizontalAlignment="Center" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>

                                    <!-- CURRENT -->
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <controls:LevelSelectorControl Title="Сurrent"
                                            Level="{Binding Editable.CurrentLevel}"
                                            LevelOptionsPairs="{Binding LevelOptionsPairs}" />
                                    </StackPanel>

                                    <!-- DESIRED -->
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <controls:LevelSelectorControl Title="Desired"
                                            Level="{Binding Editable.DesiredLevel}"
                                            LevelOptionsPairs="{Binding LevelOptionsPairs}" />
                                    </StackPanel>

                                </Grid>
                            </StackPanel>
                        </Border>

                        <Rectangle Height="1" Fill="#C4B8A8" Margin="10" />

                        <Border>
                            <StackPanel>
                                <TextBlock Text="AA"
                                   Foreground="#EED18C"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0 0 0 10"  HorizontalAlignment="Center" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>

                                    <controls:TalentLevelControl
                                        Grid.Column="0"
                                        Title="Current"
                                        Level="{Binding Editable.AutoAttack.CurrentLevel}" />
                                    <controls:TalentLevelControl
                                        Grid.Column="1"
                                        Title="Desired"
                                        Level="{Binding Editable.AutoAttack.DesiredLevel}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Rectangle Height="1" Fill="#C4B8A8" Margin="10" />

                        <Border>
                            <StackPanel>
                                <TextBlock Text="Elemental"
                                   Foreground="#EED18C"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0 0 0 10"  HorizontalAlignment="Center" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>

                                    <controls:TalentLevelControl
                                        Grid.Column="0"
                                        Title="Current"
                                        Level="{Binding Editable.Elemental.CurrentLevel}" />
                                    <controls:TalentLevelControl
                                        Grid.Column="1"
                                        Title="Desired"
                                        Level="{Binding Editable.Elemental.DesiredLevel}" />

                                </Grid>
                            </StackPanel>
                        </Border>

                        <Rectangle Height="1" Fill="#C4B8A8" Margin="10" />

                        <Border>
                            <StackPanel>
                                <TextBlock Text="Burst"
                                   Foreground="#EED18C"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0 0 0 10" HorizontalAlignment="Center" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>

                                    <controls:TalentLevelControl
                                        Grid.Column="0"
                                        Title="Current"
                                        Level="{Binding Editable.Burst.CurrentLevel}" />
                                    <controls:TalentLevelControl
                                        Grid.Column="1"
                                        Title="Desired"
                                        Level="{Binding Editable.Burst.DesiredLevel}" />
                                </Grid>
                                <Rectangle Height="1" Fill="#C4B8A8" Margin="10" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">

                    <Button Content="✖"
                        Width="48" Height="48"
                        Margin="0 0 25 0"
                        FontSize="22"
                        Background="#C84646"
                        Foreground="White"
                        Command="{Binding CancelCommand}">
                        <Button.Style>
                            <Style TargetType="Button" />
                        </Button.Style>
                    </Button>
                    <Button  Content="✔"
                        Width="48" Height="48"
                        Margin="25 0 0 0"
                        FontSize="22"
                        Background="#419D5F"
                        Foreground="White"
                        Command="{Binding SaveCommand}">
                        <Button.Style>
                            <Style TargetType="Button" />
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>