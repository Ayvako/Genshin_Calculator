<Window x:Class="Genshin_Calculator.Presentation.Features.Dialogs.AddMaterialsDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="WidthAndHeight"
        MinWidth="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="15" Background="{StaticResource MyGradientBrush}" BorderBrush="Black" BorderThickness="1" Padding="15">
        <StackPanel>
            <ItemsControl ItemsSource="{Binding MaterialWrappers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,3" Background="#1E2127" BorderBrush="#323842" BorderThickness="1" CornerRadius="8" Padding="10,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="6"
                                    Background="{Binding Material.Rarity, Converter={StaticResource RarityToBrushConverter}}">
                                    <Image Source="{Binding Material.ImagePath}" Margin="3" />
                                </Border>

                                <TextBlock Grid.Column="1" Text="{Binding Material.Name}"
                                    VerticalAlignment="Center" Margin="12,0"
                                    FontSize="13" Foreground="#D1D5DB" FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis" />

                                <Border Grid.Column="2" Background="#14161A" CornerRadius="6" Padding="6,2">
                                    <StackPanel Orientation="Horizontal">

                                        <StackPanel Width="75" VerticalAlignment="Center">
                                            <TextBlock Text="IN STOCK" FontSize="8" Foreground="#6B7280" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBox Text="{Binding Material.Amount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}"
                                                MaxLength="9" Background="Transparent" BorderThickness="0"
                                                Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="13"
                                                HorizontalContentAlignment="Center" CaretBrush="White"
                                                PreviewTextInput="NumericOnly_PreviewTextInput"
                                                DataObject.Pasting="NumericOnly_Pasting" />
                                        </StackPanel>

                                        <TextBlock Text="+" Foreground="#374151" FontSize="14" VerticalAlignment="Center" Margin="2,6,2,0" />

                                        <StackPanel Width="80" VerticalAlignment="Center">
                                            <TextBlock Text="ADD" FontSize="8" Foreground="#10B981" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <Border Background="#064E3B" CornerRadius="4" Margin="2,1">
                                                <TextBox Text="{Binding AdditionAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}"
                                                    MaxLength="9" Background="Transparent" BorderThickness="0"
                                                    Foreground="#34D399" FontWeight="Bold" FontSize="13"
                                                    HorizontalContentAlignment="Center" CaretBrush="#34D399"
                                                    PreviewTextInput="NumericOnly_PreviewTextInput"
                                                    DataObject.Pasting="NumericOnly_Pasting" />
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Text="=" Foreground="#374151" FontSize="14" VerticalAlignment="Center" Margin="2,6,2,0" />

                                        <StackPanel Width="85" VerticalAlignment="Center">
                                            <TextBlock Text="TOTAL" FontSize="8" Foreground="#6B7280" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding TotalResult}"
                                                Foreground="#FBBF24" FontWeight="Black" FontSize="14"
                                                HorizontalAlignment="Center" Margin="0,1,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button Content="✖" Style="{StaticResource RoundShadowButtonStyle}"
                        Margin="0,0,15,0" Width="35" Height="35"
                        Background="#C84646" Foreground="White"
                        Command="{Binding CloseCommand}" IsCancel="True" />

                <Button Content="✔" Style="{StaticResource RoundShadowButtonStyle}"
                        Margin="15,0,0,0" Width="35" Height="35"
                        Background="#419D5F" Foreground="White"
                        Command="{Binding SaveCommand}" IsDefault="True" />
            </StackPanel>

        </StackPanel>
    </Border>
</Window>