<Window x:Class="Genshin_Calculator.Presentation.Features.Dialogs.UpgradeCharacterDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:components="clr-namespace:Genshin_Calculator.Presentation.Controls"
        Height="580" Width="480"
        MinWidth="420" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        TextElement.Foreground="#EAE6D8"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Title="Upgrade Character">

    <Window.Resources>

        <!-- ═══ Brushes ═══ -->
        <LinearGradientBrush x:Key="DialogBgBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#16182A" Offset="0" />
            <GradientStop Color="#0F1018" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="HeaderGoldBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#C8A84B" Offset="0" />
            <GradientStop Color="#E8D07A" Offset="0.5" />
            <GradientStop Color="#C8A84B" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SaveBtnBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3A8C5C" Offset="0" />
            <GradientStop Color="#4DB87A" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CancelBtnBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8C3A3A" Offset="0" />
            <GradientStop Color="#C05050" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="GoldAccentBrush" Color="#C8A84B" />
        <SolidColorBrush x:Key="MutedTextBrush"  Color="#6B7280" />
        <SolidColorBrush x:Key="SectionBgBrush"  Color="#111320" />

        <!-- ═══ Shadows ═══ -->
        <DropShadowEffect x:Key="WindowShadow"  BlurRadius="40" ShadowDepth="6" Opacity="0.75" Color="Black" />
        <DropShadowEffect x:Key="GoldGlow"      BlurRadius="14" ShadowDepth="0" Opacity="0.45" Color="#C8A84B" />
        <DropShadowEffect x:Key="CardShadow"    BlurRadius="10" ShadowDepth="0" Opacity="0.55" Color="Black" />
        <DropShadowEffect x:Key="BtnShadow"     BlurRadius="16" ShadowDepth="2" Opacity="0.55" Color="Black" />
        <DropShadowEffect x:Key="GreenGlow"     BlurRadius="14" ShadowDepth="0" Opacity="0.5"  Color="#3A8C5C" />

        <!-- ═══ Scrollbar ═══ -->
        <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="4" Background="#3A3E55" Margin="2,0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Action button ═══ -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground"      Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Effect"          Value="{StaticResource BtnShadow}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Section label ═══ -->
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"            Value="11" />
            <Setter Property="FontWeight"          Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground"          Value="#C8A84B" />
            <Setter Property="Margin"              Value="0,0,0,2" />
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════
         ROOT
    ══════════════════════════════════ -->
    <Border CornerRadius="16"
            Background="{StaticResource DialogBgBrush}"
            BorderBrush="#2A2E45"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Header       -->
                <RowDefinition Height="*" />
                <!-- Scroll body  -->
                <RowDefinition Height="Auto" />
                <!-- Footer       -->
            </Grid.RowDefinitions>

            <!-- ══ HEADER ══ -->
            <Border Grid.Row="0"
                    CornerRadius="16,16,0,0"
                    BorderBrush="#22263A"
                    BorderThickness="0,0,0,1"
                    Padding="22,18,22,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1C1F30" Offset="0" />
                        <GradientStop Color="#14172A" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Diamond icon -->
                    <Border Grid.Column="0"
                            Width="22" Height="22"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#C8A84B" Offset="0" />
                                <GradientStop Color="#E8D07A" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.RenderTransform>
                            <RotateTransform Angle="45" CenterX="11" CenterY="11" />
                        </Border.RenderTransform>
                    </Border>

                    <!-- Title + subtitle -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="16"
                                   FontWeight="Bold"
                                   Effect="{StaticResource GoldGlow}">
                            <TextBlock.Text>
                                <Binding Path="Character.Name" StringFormat="UPGRADE — {0}" FallbackValue="CHARACTER UPGRADE" />
                            </TextBlock.Text>
                            <TextBlock.Foreground>
                                <Binding Path="Character.Assets.Rarity"
                                         Converter="{StaticResource RarityToBrushConverter}"
                                         FallbackValue="#E8D07A" />
                            </TextBlock.Foreground>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ SCROLL BODY ══ -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="18,0,18,0">
                <StackPanel>

                    <!-- ── Required materials ── -->
                    <StackPanel Margin="0,18,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Rectangle Width="40" Height="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0" />
                                        <GradientStop Color="#C8A84B"     Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <TextBlock Text="REQUIRED MATERIALS"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Margin="0" />
                            <Rectangle Width="40" Height="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#C8A84B"     Offset="0" />
                                        <GradientStop Color="Transparent" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Materials}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.OpenAddItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding TargetMaterial}"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="0" Margin="5" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="CardBorder"
                                                        Width="64" Height="84"
                                                        CornerRadius="10"
                                                        BorderBrush="#2E3140"
                                                        BorderThickness="1"
                                                        Background="{Binding TargetMaterial.Rarity, Converter={StaticResource RarityToBrushConverter}}"
                                                        Opacity="{Binding IsCollected, Converter={StaticResource BoolToOpacityConverter}}"
                                                        Effect="{StaticResource CardShadow}">

                                                    <Grid>
                                                        <!-- Inner top highlight -->
                                                        <Border CornerRadius="10,10,0,0" Height="22" VerticalAlignment="Top" Opacity="0.18">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                    <GradientStop Color="White"       Offset="0" />
                                                                    <GradientStop Color="Transparent" Offset="1" />
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>

                                                        <!-- Amount / Missing badge -->
                                                        <Border VerticalAlignment="Top"
                                                                CornerRadius="9,9,0,0"
                                                                Height="22"
                                                                Background="#BB000000">
                                                            <TextBlock VerticalAlignment="Center"
                                                                       HorizontalAlignment="Center"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="{Binding MissingAmount}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCollected}" Value="True">
                                                                                <Setter Property="Text" Value="{Binding TargetMaterial.Amount}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding CraftedAmount, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" Value="True">
                                                                                <Setter Property="ToolTip" Value="{Binding CraftedAmount}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- Item image -->
                                                        <Image Source="{Binding TargetMaterial.ImagePath}"
                                                               Margin="6,26,6,6"
                                                               Stretch="Uniform"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />

                                                        <!-- Collected checkmark badge -->
                                                        <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                              Margin="0,0,-3,-3"
                                                              Visibility="{Binding IsCollected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <Ellipse Fill="#1A1C28" Width="20" Height="20"
                                                                     Stroke="#4CAF50" StrokeThickness="1.5" />
                                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                       Text="&#xE73E;"
                                                                       Foreground="#4CAF50"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="Bold" />
                                                        </Grid>
                                                    </Grid>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="#C8A84B" />
                                                        <Setter TargetName="CardBorder" Property="Opacity"     Value="0.82" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="CardBorder" Property="Opacity" Value="0.65" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ── Crafting section ── -->
                    <StackPanel Margin="0,22,0,16">

                        <!-- Section header with divider -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Rectangle Grid.Column="0" Height="1" VerticalAlignment="Center">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0" />
                                        <GradientStop Color="#3A3E55"     Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <Border Grid.Column="1"
                                    Background="{StaticResource SectionBgBrush}"
                                    BorderBrush="#2E3140"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14,6"
                                    Margin="10,0">
                                <StackPanel>
                                    <TextBlock Text="CRAFT"
                                               Style="{StaticResource SectionLabelStyle}"
                                               Margin="0" />
                                    <TextBlock Text="Basic materials"
                                               FontSize="10"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>

                            <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3A3E55"     Offset="0" />
                                        <GradientStop Color="Transparent" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>

                        <!-- Craft cards -->
                        <ItemsControl ItemsSource="{Binding MaterialsToCraft}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.OpenAddItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="0" Margin="4" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="CraftBorder"
                                                        Width="58" Height="74"
                                                        CornerRadius="10"
                                                        BorderBrush="#2E3140"
                                                        BorderThickness="1"
                                                        Background="{Binding Rarity, Converter={StaticResource RarityToBrushConverter}}"
                                                        Effect="{StaticResource CardShadow}">

                                                    <Grid>
                                                        <!-- Inner top highlight -->
                                                        <Border CornerRadius="10,10,0,0" Height="18" VerticalAlignment="Top" Opacity="0.16">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                    <GradientStop Color="White"       Offset="0" />
                                                                    <GradientStop Color="Transparent" Offset="1" />
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>

                                                        <!-- Amount badge -->
                                                        <Border VerticalAlignment="Top"
                                                                CornerRadius="9,9,0,0"
                                                                Height="19"
                                                                Background="#BB000000">
                                                            <TextBlock Text="{Binding Amount}"
                                                                       Foreground="#E8D07A"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>

                                                        <!-- Item image -->
                                                        <Image Source="{Binding ImagePath}"
                                                               Margin="5,22,5,5"
                                                               Stretch="Uniform"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="CraftBorder" Property="BorderBrush" Value="#C8A84B" />
                                                        <Setter TargetName="CraftBorder" Property="Opacity"     Value="0.82" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="CraftBorder" Property="Opacity" Value="0.65" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ══ FOOTER ══ -->
            <Border Grid.Row="2"
                    CornerRadius="0,0,16,16"
                    BorderBrush="#22263A"
                    BorderThickness="0,1,0,0"
                    Padding="22,14,22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#14172A" Offset="0" />
                        <GradientStop Color="#0F1018" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">

                        <Button Command="{Binding CancelCommand}"
                                IsCancel="True"
                                Width="115" Height="40"
                                Margin="0,0,10,0"
                                Background="{StaticResource CancelBtnBrush}"
                                Padding="12,0"
                                Style="{StaticResource ActionButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✖" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Cancel" FontSize="13" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SaveCommand}"
                                IsDefault="True"
                                Width="125" Height="40"
                                Background="{StaticResource SaveBtnBrush}"
                                Padding="12,0"
                                Style="{StaticResource ActionButtonStyle}">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.5" Color="#3A8C5C" />
                            </Button.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✔" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Confirm" FontSize="13" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>