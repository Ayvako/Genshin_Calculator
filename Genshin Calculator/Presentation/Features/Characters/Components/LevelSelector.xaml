<UserControl x:Class="Genshin_Calculator.Presentation.Features.Characters.Components.LevelSelectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:сomponents="clr-namespace:Genshin_Calculator.Presentation.Features.Characters.Components"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=сomponents:LevelSelectorControl}"

             x:Name="root">

    <UserControl.Resources>
        <Style x:Key="LevelActionButtonStyle" BasedOn="{StaticResource RoundedButtonStyle}" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="LevelValueButtonStyle" BasedOn="{StaticResource RoundedButtonStyle}" TargetType="Button">
            <Setter Property="Width" Value="70" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <StackPanel HorizontalAlignment="Center">
        <TextBlock Text="{Binding Title, ElementName=root}"
                   Foreground="#AAA"
                   FontSize="12"
                   Margin="0,0,0,4"
                   HorizontalAlignment="Center" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

            <Button Style="{StaticResource LevelActionButtonStyle}"
                    Command="{Binding DecreaseLevelCommand, ElementName=root}"
                    IsEnabled="{Binding Level, ElementName=root, Converter={StaticResource LevelGreaterThanOneConverter}}">
                <TextBlock Text="-" Margin="0,-8,0,0" FontSize="28" />
            </Button>

            <ToggleButton x:Name="TogglePopupButton"
                Style="{StaticResource LevelToggleButtonStyle}"
                IsChecked="{Binding IsPopupOpen, ElementName=root, Mode=TwoWay}"
                PreviewMouseLeftButtonDown="TogglePopupButtonPreviewMouseLeftButtonDown">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="10*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="3*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding Level, ElementName=root}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#2C2C2C"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />

                    <Rectangle Grid.Row="1"
                               Height="1"
                               Fill="#C4B8A8" />

                    <TextBlock Grid.Row="2"
                               Text="▼"
                               FontSize="6"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </ToggleButton>

            <Popup x:Name="LevelPopup"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=TogglePopupButton}"
                   AllowsTransparency="True"
                   PopupAnimation="None"
                   Focusable="False"
                   IsOpen="{Binding IsPopupOpen, ElementName=root}">

                <Border Background="#1E1E1E"
                        BorderBrush="#444"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="6"
                        SnapsToDevicePixels="True">

                    <StackPanel>
                        <Button Content="1"
                                Style="{StaticResource LevelValueButtonStyle}"
                                Command="{Binding SelectLevelCommand, ElementName=root}"
                                CommandParameter="1" />

                        <ItemsControl ItemsSource="{Binding LevelOptionsPairs, ElementName=root}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="{Binding Level}"
                                                Style="{StaticResource LevelValueButtonStyle}"
                                                Command="{Binding SelectLevelCommand, ElementName=root}"
                                                CommandParameter="{Binding Level}" />

                                        <Button Content="{Binding Ascended}"
                                                Style="{StaticResource LevelValueButtonStyle}"
                                                Margin="6,0,0,0"
                                                Command="{Binding SelectLevelCommand, ElementName=root}"
                                                CommandParameter="{Binding Ascended}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="90"
                                Style="{StaticResource LevelValueButtonStyle}"
                                Command="{Binding SelectLevelCommand, ElementName=root}"
                                CommandParameter="90" />
                    </StackPanel>
                </Border>
            </Popup>

            <Button Style="{StaticResource LevelActionButtonStyle}"
                    Command="{Binding IncreaseLevelCommand, ElementName=root}"
                    IsEnabled="{Binding Level, ElementName=root, Converter={StaticResource LevelLessThanConverter}, ConverterParameter=90}">
                <TextBlock Text="+" Margin="0,-8,0,0" FontSize="28" />
            </Button>

        </StackPanel>
    </StackPanel>
</UserControl>